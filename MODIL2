<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Multi Language Page</title>

<style>
body{
    margin:0;
    font-family:Arial, sans-serif;
    text-align:center;
    background:#111;
    color:white;
}

/* زر الرجوع */
.back-btn{
    position:fixed;
    top:10px;
    left:10px;
    background:#00cc66;
    color:white;
    border:none;
    padding:5px 10px;
    font-size:12px;
    border-radius:5px;
    cursor:pointer;
}

/* ازرار اللغات */
.lang-btn{
    margin:5px;
    padding:8px 15px;
    border:none;
    border-radius:5px;
    cursor:pointer;
    background:#00cc66;
    color:white;
}

/* النص */
.content{
    margin-top:80px;
    font-size:20px;
}
</style>
</head>

<body>

<!-- زر الرجوع -->
<button class="back-btn" onclick="goBack()">↩</button>

<!-- ازرار تغيير اللغة -->
<div style="margin-top:40px;">
    <button class="lang-btn" onclick="setLang('ar')">العربية</button>
    <button class="lang-btn" onclick="setLang('en')">English</button>
    <button class="lang-btn" onclick="setLang('fr')">Français</button>
</div>

<!-- المحتوى -->
<div class="content" id="text">
    مرحبا بك في موقعي
</div>

<script>
function setLang(lang){
    let text = document.getElementById("text");

    if(lang === "ar"){
        document.documentElement.lang = "ar";
        text.innerHTML = "مرحبا بك في موقعي";
    }
    if(lang === "en"){
        document.documentElement.lang = "en";
        text.innerHTML = "Welcome to my website";
    }
    if(lang === "fr"){
        document.documentElement.lang = "fr";
        text.innerHTML = "Bienvenue sur mon site";
    }
}

function goBack(){
    window.location.href = "green.html";
}
</script>

</body>
</html>
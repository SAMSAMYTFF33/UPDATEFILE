<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Multi Lang Modern</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    height:100vh;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    background:linear-gradient(135deg,#003300,#000000);
    color:white;
    text-align:center;
}

/* زر الرجوع الدائري */
.back{
    position:fixed;
    top:15px;
    left:15px;
    width:35px;
    height:35px;
    border-radius:50%;
    border:none;
    background:#00ff88;
    color:black;
    font-weight:bold;
    cursor:pointer;
    box-shadow:0 0 10px #00ff88;
}

/* صندوق المحتوى */
.card{
    background:rgba(255,255,255,0.05);
    padding:30px;
    border-radius:15px;
    backdrop-filter:blur(10px);
    box-shadow:0 0 20px rgba(0,255,100,0.4);
}

h1{
    margin-bottom:20px;
}

/* ازرار اللغة */
.langs button{
    margin:5px;
    padding:8px 18px;
    border:none;
    border-radius:20px;
    cursor:pointer;
    background:#00cc66;
    color:white;
    transition:0.3s;
}

.langs button:hover{
    background:#00ff88;
}
</style>
</head>

<body>

<button class="back" onclick="window.location='green.html'">←</button>

<div class="card">
    <h1 id="title">مرحبا بك</h1>
    <p id="desc">اختر لغتك المفضلة</p>

    <div class="langs">
        <button onclick="changeLang('ar')">العربية</button>
        <button onclick="changeLang('en')">English</button>
        <button onclick="changeLang('fr')">Français</button>
    </div>
</div>

<script>

const content = {
    ar:{
        title:"مرحبا بك",
        desc:"اختر لغتك المفضلة"
    },
    en:{
        title:"Welcome",
        desc:"Choose your preferred language"
    },
    fr:{
        title:"Bienvenue",
        desc:"Choisissez votre langue préférée"
    }
};

function changeLang(lang){
    document.documentElement.lang = lang;
    document.documentElement.dir = (lang === "ar") ? "rtl" : "ltr";
    document.getElementById("title").innerText = content[lang].title;
    document.getElementById("desc").innerText = content[lang].desc;

    localStorage.setItem("lang", lang);
}

window.onload = function(){
    let savedLang = localStorage.getItem("lang") || "ar";
    changeLang(savedLang);
};

</script>

</body>
</html>
{
"template": "<!DOCTYPE html>\n<html lang=\"ar\" dir=\"rtl\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>{{TITLE}}</title>\n  <style>\n\n@font-face {\n  font-family: 'Tajawal';\n  src: url('file:///storage/emulated/0/Android/data/com.S2/files/Tajawal-Regular.ttf') format('truetype');\n  font-weight: 400;\n}\n\n@font-face {\n  font-family: 'Tajawal';\n  src: url('file:///storage/emulated/0/Android/data/com.S2/files/Tajawal-Bold.ttf') format('truetype');\n  font-weight: 700;\n}\n\n:root {\n  --primary-color: #3b5c87;\n  --secondary-color: #249681;\n  --accent-color: #e0a01f;\n  --bg-color: #f6f8fb;\n  --card-bg: rgba(255, 255, 255, 0.85);\n  --text-dark: #343e47;\n  --text-light: #6a798a;\n  --glass-border: rgba(255, 255, 255, 0.7);\n  --glass-shadow: 0 4px 20px rgba(59, 92, 135, 0.06);\n  --neon-glow: 0 0 15px rgba(59, 92, 135, 0.15);\n}\n\n.dark-mode {\n  --primary-color: #79b3f0;\n  --secondary-color: #59d6bd;\n  --accent-color: #f7ce6a;\n  --bg-color: #171f28;\n  --card-bg: rgba(31, 41, 54, 0.75);\n  --text-dark: #eef2f5;\n  --text-light: #93a6b8;\n  --glass-border: rgba(255, 255, 255, 0.08);\n  --glass-shadow: 0 8px 30px rgba(0, 0, 0, 0.35);\n  --neon-glow: 0 0 15px rgba(121, 179, 240, 0.2), 0 0 30px rgba(89, 214, 189, 0.1);\n}\n\n* { box-sizing: border-box; margin: 0; padding: 0; }\n\nbody {\n  font-family: 'Tajawal', sans-serif;\n  background: var(--bg-color);\n  background-image: radial-gradient(circle at 10% 20%, rgba(121, 179, 240, 0.04) 0%, transparent 40%),\n                    radial-gradient(circle at 90% 80%, rgba(89, 214, 189, 0.04) 0%, transparent 40%);\n  background-attachment: fixed;\n  color: var(--text-dark);\n  line-height: 1.9;\n  padding-bottom: 50px;\n  transition: background 0.4s ease, color 0.4s ease;\n  overflow-x: hidden;\n}\n\n::-webkit-scrollbar { width: 8px; }\n::-webkit-scrollbar-track { background: transparent; }\n::-webkit-scrollbar-thumb { background: var(--secondary-color); border-radius: 10px; }\n\n.card, .side-menu, .modal-content, .edit-popup, .confirm-popup {\n  background: var(--card-bg);\n  backdrop-filter: blur(16px);\n  -webkit-backdrop-filter: blur(16px);\n  border: 1px solid var(--glass-border);\n  box-shadow: var(--glass-shadow);\n}\n\nheader {\n  position: relative;\n  padding: 80px 20px 60px;\n  text-align: center;\n  background: transparent;\n  border-bottom: 1px solid var(--glass-border);\n  overflow: hidden;\n}\n\nh1 {\n  font-weight: 800;\n  font-size: 2.6rem;\n  background: linear-gradient(45deg, var(--primary-color), var(--secondary-color));\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  text-shadow: var(--neon-glow);\n  margin-bottom: 15px;\n}\n\n.container { max-width: 1000px; margin: auto; padding: 40px 20px; }\n\n.section-block { margin-bottom: 60px; animation: fadeInUp 0.6s ease forwards; }\n\n@keyframes fadeInUp {\n  from { opacity: 0; transform: translateY(15px); }\n  to { opacity: 1; transform: translateY(0); }\n}\n\nh2 {\n  font-size: 1.7rem;\n  font-weight: 700;\n  color: var(--primary-color);\n  margin-bottom: 30px;\n  display: inline-block;\n  position: relative;\n}\n\n.section-intro { font-size: 1.15rem; color: var(--text-dark); margin-bottom: 30px; line-height: 2; }\n\n.cards-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\n  gap: 25px;\n}\n\n.card {\n  border-radius: 16px;\n  padding: 30px;\n  transition: all 0.3s ease;\n  position: relative;\n  overflow: hidden;\n}\n\n.card:hover {\n  transform: translateY(-5px);\n  box-shadow: 0 10px 30px rgba(0,0,0,0.08);\n}\n.dark-mode .card:hover { box-shadow: 0 10px 30px rgba(0,0,0,0.4); }\n\nh3 { font-size: 1.3rem; color: var(--secondary-color); margin-bottom: 15px; display: flex; align-items: center; gap: 10px; font-weight: 700; }\np { font-size: 1.15rem; font-weight: 400; color: var(--text-dark); line-height: 2; text-align: justify; }\n\n.menu-btn {\n  position: fixed; top: 20px; left: 20px; font-size: 24px; width: 50px; height: 50px;\n  border-radius: 15px; background: var(--card-bg); backdrop-filter: blur(10px); color: var(--primary-color);\n  border: 1px solid var(--glass-border); cursor: pointer; z-index: 1000; display: flex; align-items: center; justify-content: center;\n}\n\n.side-menu {\n  position: fixed; top: 0; left: -320px; width: 320px; height: 100vh;\n  padding: 90px 25px 25px; transition: left 0.4s; border-radius: 0 30px 30px 0;\n  z-index: 999; display: flex; flex-direction: column; gap: 15px;\n}\n\n.side-menu.open { left: 0; }\n.side-menu button {\n  font-family: 'Tajawal', sans-serif; font-size: 16px; font-weight: 700; padding: 15px; border-radius: 12px;\n  border: 1px solid var(--glass-border); cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px;\n  background: rgba(255, 255, 255, 0.05); color: var(--text-dark); transition: 0.3s;\n}\n.side-menu button:hover { background: rgba(0,0,0,0.05); }\n.dark-mode .side-menu button:hover { background: rgba(255,255,255,0.1); }\n\n.edit-mode-active .edit-btn { background: rgba(36, 150, 129, 0.2); }\n.edit-mode-active [contenteditable=\"true\"] { outline: 2px dashed var(--secondary-color); background: rgba(36, 150, 129, 0.1); border-radius: 8px; padding: 4px 8px; }\n\n.edit-popup, .confirm-popup {\n  position: fixed; display: flex; gap: 10px; border-radius: 50px; padding: 8px 15px; z-index: 2000;\n  transform: translate(-50%, -100%); pointer-events: none; opacity: 0; transition: 0.2s;\n}\n\n.edit-popup.show, .confirm-popup.show { pointer-events: all; opacity: 1; transform: translate(-50%, -120%); }\n\n.edit-popup button, .confirm-popup button {\n  width: 42px; height: 42px; border-radius: 50%; border: none; font-size: 18px; cursor: pointer;\n  display: flex; align-items: center; justify-content: center; transition: 0.2s; box-shadow: 0 4px 10px rgba(0,0,0,0.2);\n}\n\n.delete-btn { background: #e74c3c; color: white; }\n.edit-btn-popup { background: var(--secondary-color); color: white; }\n.cancel-btn-popup { background: #95a5a6; color: white; }\n.confirm-edit-btn { background: #2ecc71; color: white; }\n.cancel-edit-btn { background: #e74c3c; color: white; }\n\n.modal-overlay {\n  position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(4px);\n  display: flex; align-items: center; justify-content: center; z-index: 3000; opacity: 0; pointer-events: none; transition: 0.3s;\n}\n\n.modal-overlay.show { opacity: 1; pointer-events: all; }\n\n.modal-content {\n  width: 90%; max-width: 500px; border-radius: 20px; padding: 30px; max-height: 85vh; overflow-y: auto;\n  border: 1px solid rgba(255, 255, 255, 0.1); box-shadow: 0 20px 40px rgba(0,0,0,0.4);\n}\n\n.input-group { margin-bottom: 20px; }\n.input-group label { display: block; margin-bottom: 8px; color: var(--text-dark); font-weight: 700; }\n.input-group input, .input-group textarea {\n  width: 100%; padding: 12px 15px; border-radius: 12px; border: 1px solid var(--glass-border);\n  background: rgba(0, 0, 0, 0.05); color: var(--text-dark); font-family: 'Tajawal', sans-serif; font-size: 1rem;\n}\n.dark-mode .input-group input, .dark-mode .input-group textarea { background: rgba(255, 255, 255, 0.05); }\n\n.modal-buttons { display: flex; gap: 15px; margin-top: 30px; }\n.modal-buttons button { flex: 1; padding: 12px; border-radius: 12px; border: none; cursor: pointer; font-weight: 700; font-family: 'Tajawal'; font-size: 1rem; }\n\n.edit-toast {\n  position: fixed; bottom: 20px; right: 20px; background: rgba(23, 31, 40, 0.95); color: #fff;\n  padding: 12px 25px; border-radius: 50px; font-weight: 500; border: 1px solid var(--secondary-color);\n  z-index: 2000; opacity: 0; transition: 0.3s; pointer-events: none; transform: translateY(20px);\n}\n.edit-toast.show { opacity: 1; transform: translateY(0); }\n</style>\n </head>\n <body class=\"dark-mode edit-mode-active\">\n  <script>\n(function() {\ntry {\nconst savedTheme = localStorage.getItem('darkMode');\nif (savedTheme === 'enabled') {\ndocument.body.classList.add('dark-mode');\n}\n} catch(e) {}\n})();\n</script> \n<button class=\"menu-btn\" onclick=\"toggleMenu()\">☰</button>\n  <div class=\"side-menu\" id=\"menu\">\n    <button class=\"theme-btn\" onclick=\"toggleTheme()\">الوضع الداكن</button> \n    <button class=\"edit-btn\" onclick=\"toggleEditMode()\"><span>✓</span> إنهاء التعديل</button> \n    <button class=\"add-btn\" onclick=\"openAddModal()\"> <span>+</span> إضافة نص </button>\n  </div>\n  <header>\n   <h1 id=\"h1_0\">{{TITLE}}</h1>\n  </header>\n  <div class=\"container\" id=\"mainContainer\">\n   \n  </div>\n  \n  <div class=\"modal-overlay\" id=\"addModal\">\n   <div class=\"modal-content\">\n    <h3> إضافة نص </h3>\n    <div class=\"input-group\"><label>العنوان صفحة - اختياري</label> <input type=\"text\" id=\"inputH1\" placeholder=\"...\"></div>\n    <div class=\"input-group\"><label>النص التمهيدي - اختياري</label> <textarea id=\"inputIntro\" rows=\"3\" placeholder=\"...\"></textarea></div>\n    <div class=\"input-group\"><label>العنوان الرئيسي - اختياري</label> <input type=\"text\" id=\"inputH2\" placeholder=\"...\"></div>\n    <div class=\"input-group\"><label>العنوان الفرعي مع نص - اختياري</label> <input type=\"text\" id=\"inputCardTitle\" placeholder=\"العنوان الفرعي...\"> <textarea id=\"inputCardText\" rows=\"2\" placeholder=\"النص داخل العنوان الفرعي ...\" style=\"margin-top:10px;\"></textarea></div>\n    <div class=\"modal-buttons\"><button onclick=\"addNewContent()\">✅ إضافة</button> <button onclick=\"closeAddModal()\">❌ إلغاء</button></div>\n   </div>\n  </div> \n\n  <div class=\"modal-overlay\" id=\"deleteConfirmModal\">\n   <div class=\"modal-content\" style=\"max-width: 400px; text-align: center;\">\n    <h3 style=\"color: var(--primary-color); margin-bottom: 20px;\">⚠️ تأكيد الحذف</h3>\n    <p style=\"margin-bottom: 30px; font-size: 1.1rem;\">هل أنت متأكد من حذف هذا العنصر؟</p>\n    <div class=\"modal-buttons\"><button onclick=\"confirmDeleteElement()\" style=\"background: #dc3545; color: white;\">🗑️ تأكيد الحذف</button> <button onclick=\"cancelDeleteModal()\" style=\"background: var(--secondary-color); color: white;\">❌ إلغاء</button></div>\n   </div>\n  </div> \n\n  <div class=\"edit-popup\" id=\"editPopup\">\n    <button class=\"delete-btn\" onclick=\"deleteElement()\">🗑️</button> \n    <button class=\"edit-btn-popup\" onclick=\"prepareEdit()\">✎</button> \n    <button class=\"cancel-btn-popup\" onclick=\"cancelPopup()\">✖</button>\n  </div> \n  <div class=\"confirm-popup\" id=\"confirmPopup\">\n    <button class=\"confirm-edit-btn\" onclick=\"confirmEdit()\">✅</button> \n    <button class=\"cancel-edit-btn\" onclick=\"cancelEdit()\">❌</button>\n  </div>\n\n  <div class=\"edit-toast\" id=\"editToast\">وضع التعديل نشط - اضغط لاختيار نص</div>\n\n<script>\nlet editMode = false;\nlet currentEditElement = null;\nlet originalText = '';\nlet longPressTimer = null;\nlet elementToDelete = null;\n\nfunction getCurrentFileName() {\n    let path = window.location.pathname;\n    return path.split('/').pop() || 'index.html'; \n}\n\nfunction giveUniqueIds() {\n    document.querySelectorAll('p:not(.card p)').forEach((el, index) => { if (!el.id) el.id = 'p_' + index; });\n    document.querySelectorAll('.card p').forEach((el, index) => { if (!el.id) el.id = 'card_p_' + index; });\n    document.querySelectorAll('h1').forEach((el, index) => { if (!el.id) el.id = 'h1_' + index; });\n    document.querySelectorAll('h2').forEach((el, index) => { if (!el.id) el.id = 'h2_' + index; });\n    document.querySelectorAll('h3').forEach((el, index) => { if (!el.id) el.id = 'h3_' + index; });\n    document.querySelectorAll('.section-intro').forEach((el, index) => { if (!el.id) el.id = 'intro_' + index; });\n}\n\nfunction loadThemePreference() {\n    const savedTheme = localStorage.getItem('darkMode');\n    if (savedTheme === 'enabled') {\n        document.body.classList.add('dark-mode');\n        document.querySelector('.theme-btn').innerHTML = 'الوضع الفاتح';\n    } else {\n        document.body.classList.remove('dark-mode');\n        document.querySelector('.theme-btn').innerHTML = 'الوضع الداكن';\n    }\n}\n\nfunction loadEditModePreference() {\n    const savedEditMode = localStorage.getItem('editMode');\n    if (savedEditMode === 'enabled') {\n        editMode = true;\n        document.body.classList.add('edit-mode-active');\n        document.querySelector('.edit-btn').innerHTML = '<span>✓</span> إنهاء التعديل';\n    } else {\n        editMode = false;\n        document.body.classList.remove('edit-mode-active');\n        document.querySelector('.edit-btn').innerHTML = '<span>✎</span> تفعيل التعديل';\n        document.querySelectorAll('[contenteditable=\"true\"]').forEach(el => el.removeAttribute('contenteditable'));\n    }\n}\n\nwindow.addEventListener('load', function() {\n    loadThemePreference();\n    loadEditModePreference();\n    hideEditPopup();\n    hideConfirmPopup();\n    giveUniqueIds();\n});\n\nfunction toggleMenu() { document.getElementById(\"menu\").classList.toggle(\"open\"); }\n\nfunction toggleTheme() {\n    document.body.classList.toggle(\"dark-mode\");\n    let btn = document.querySelector('.theme-btn');\n    if(document.body.classList.contains('dark-mode')) {\n        btn.innerHTML = 'الوضع الفاتح';\n        localStorage.setItem('darkMode', 'enabled');\n    } else {\n        btn.innerHTML = 'الوضع الداكن';\n        localStorage.setItem('darkMode', 'disabled');\n    }\n}\n\nfunction toggleEditMode() {\n    editMode = !editMode;\n    const editBtn = document.querySelector('.edit-btn');\n    if (editMode) {\n        document.body.classList.add('edit-mode-active');\n        editBtn.innerHTML = '<span>✓</span> إنهاء التعديل';\n        localStorage.setItem('editMode', 'enabled');\n        showToast('وضع التعديل نشط - اضغط لاختيار نص');\n    } else {\n        document.body.classList.remove('edit-mode-active');\n        editBtn.innerHTML = '<span>✎</span> تفعيل التعديل';\n        localStorage.setItem('editMode', 'disabled');\n        document.querySelectorAll('[contenteditable=\"true\"]').forEach(el => el.removeAttribute('contenteditable'));\n        hideEditPopup(); hideConfirmPopup();\n    }\n}\n\nfunction openAddModal() {\n    document.getElementById('addModal').classList.add('show');\n    document.getElementById('menu').classList.remove('open');\n}\n\nfunction closeAddModal() {\n    document.getElementById('addModal').classList.remove('show');\n    ['inputH1', 'inputIntro', 'inputH2', 'inputCardTitle', 'inputCardText'].forEach(id => document.getElementById(id).value = '');\n}\n\nfunction addNewContent() {\n    const h1Text = document.getElementById('inputH1').value.trim();\n    const introText = document.getElementById('inputIntro').value.trim();\n    const h2Text = document.getElementById('inputH2').value.trim();\n    const cardTitle = document.getElementById('inputCardTitle').value.trim();\n    const cardText = document.getElementById('inputCardText').value.trim();\n    const container = document.getElementById('mainContainer');\n\n    if (h1Text !== '') {\n        const header = document.querySelector('header');\n        if (header) {\n            const newH1 = document.createElement('h1');\n            newH1.textContent = h1Text;\n            header.appendChild(newH1);\n            newH1.addEventListener('touchstart', handleTouchStart, {passive: false});\n        }\n    }\n\n    if (h2Text !== '' || introText !== '' || cardTitle !== '' || cardText !== '') {\n        const newSection = document.createElement('section');\n        newSection.className = 'section-block';\n        if (h2Text !== '') {\n            const h2 = document.createElement('h2'); h2.textContent = h2Text;\n            newSection.appendChild(h2); h2.addEventListener('touchstart', handleTouchStart, {passive: false});\n        }\n        if (introText !== '') {\n            const intro = document.createElement('p'); intro.className = 'section-intro'; intro.textContent = introText;\n            newSection.appendChild(intro); intro.addEventListener('touchstart', handleTouchStart, {passive: false});\n        }\n        if (cardTitle !== '' || cardText !== '') {\n            const cardsGrid = document.createElement('div'); cardsGrid.className = 'cards-grid';\n            const card = document.createElement('div'); card.className = 'card';\n            if (cardTitle !== '') {\n                const cardH3 = document.createElement('h3'); cardH3.textContent = cardTitle;\n                card.appendChild(cardH3); cardH3.addEventListener('touchstart', handleTouchStart, {passive: false});\n            }\n            if (cardText !== '') {\n                const cardP = document.createElement('p'); cardP.textContent = cardText;\n                card.appendChild(cardP); cardP.addEventListener('touchstart', handleTouchStart, {passive: false});\n            }\n            cardsGrid.appendChild(card); newSection.appendChild(cardsGrid);\n        }\n        container.appendChild(newSection);\n    }\n    giveUniqueIds(); closeAddModal(); saveChanges(); showToast('✅ تمت الإضافة بنجاح');\n}\n\nfunction saveChanges() {\n    document.getElementById('editPopup').classList.remove('show');\n    document.getElementById('confirmPopup').classList.remove('show');\n    document.getElementById('addModal').classList.remove('show');\n    document.getElementById('deleteConfirmModal').classList.remove('show');\n    document.querySelectorAll('[contenteditable=\"true\"]').forEach(el => el.removeAttribute('contenteditable'));\n\n    const fileName = getCurrentFileName();\n    const htmlContent = '<!DOCTYPE html>\\n' + document.documentElement.outerHTML;\n    if (typeof AndroidBridge !== 'undefined' && AndroidBridge.saveFile) {\n        AndroidBridge.saveFile('/storage/emulated/0/Android/data/com.S2/files/' + fileName, htmlContent);\n    }\n}\n\nfunction handleTouchStart(e) {\n    if (!editMode || e.target.hasAttribute('contenteditable')) return;\n    const element = e.target.closest('h1, h2, h3, p, .section-intro, .card p');\n    if (!element) return;\n    currentEditElement = element;\n    originalText = currentEditElement.innerText;\n    const popup = document.getElementById('editPopup');\n    const touch = e.touches ? e.touches[0] : e;\n    popup.style.left = touch.clientX + 'px';\n    popup.style.top = (touch.clientY - 70) + 'px';\n    popup.classList.add('show');\n    hideConfirmPopup();\n}\n\nfunction deleteElement() {\n    if (currentEditElement) {\n        elementToDelete = currentEditElement;\n        hideEditPopup();\n        document.getElementById('deleteConfirmModal').classList.add('show');\n    }\n}\n\nfunction confirmDeleteElement() {\n    if (elementToDelete) {\n        const card = elementToDelete.closest('.card');\n        const section = elementToDelete.closest('.section-block');\n        if (card) {\n            if (elementToDelete.tagName === 'H3' || elementToDelete.tagName === 'H2') {\n                const cardsGrid = card.closest('.cards-grid');\n                card.remove(); \n                if (cardsGrid && cardsGrid.children.length === 0) cardsGrid.remove();\n            } else if (elementToDelete.tagName === 'P') {\n                elementToDelete.remove();\n                if (card.children.length === 0) { card.remove(); }\n            }\n        } else {\n            elementToDelete.remove();\n        }\n        if (section && section.querySelectorAll('h1, h2, h3, p').length === 0) section.remove();\n        closeDeleteModal(); saveChanges(); showToast('🗑️ تم الحذف بنجاح');\n    }\n}\n\nfunction cancelDeleteModal() { document.getElementById('deleteConfirmModal').classList.remove('show'); }\nfunction closeDeleteModal() { document.getElementById('deleteConfirmModal').classList.remove('show'); }\n\nfunction prepareEdit() {\n    if (currentEditElement) {\n        currentEditElement.setAttribute('contenteditable', 'true');\n        currentEditElement.focus();\n        hideEditPopup();\n        const confirmPopup = document.getElementById('confirmPopup');\n        const rect = currentEditElement.getBoundingClientRect();\n        confirmPopup.style.left = (rect.left + rect.width / 2) + 'px';\n        confirmPopup.style.top = (rect.top - 20) + 'px';\n        confirmPopup.classList.add('show');\n    }\n}\n\nfunction confirmEdit() {\n    if (currentEditElement) {\n        const newText = currentEditElement.innerText;\n        if (newText !== originalText) {\n            saveChanges(); showToast('✅ تم الحفظ');\n        }\n        currentEditElement.removeAttribute('contenteditable');\n        hideConfirmPopup(); currentEditElement = null;\n    }\n}\n\nfunction cancelEdit() {\n    if (currentEditElement) {\n        currentEditElement.innerText = originalText;\n        currentEditElement.removeAttribute('contenteditable');\n        hideConfirmPopup(); currentEditElement = null;\n    }\n}\n\nfunction hideEditPopup() { document.getElementById('editPopup').classList.remove('show'); }\nfunction hideConfirmPopup() { document.getElementById('confirmPopup').classList.remove('show'); }\nfunction cancelPopup() { hideEditPopup(); }\n\nfunction showToast(message) {\n    const toast = document.getElementById('editToast');\n    toast.textContent = message; toast.classList.add('show');\n    setTimeout(() => toast.classList.remove('show'), 1500);\n}\n\ndocument.querySelectorAll('h1, h2, h3, p, .section-intro, .card p').forEach(el => el.addEventListener('touchstart', handleTouchStart, {passive: true}));\n</script>\n</body></html>"
}
